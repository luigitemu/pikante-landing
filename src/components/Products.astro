      <!-- Verde -->
      <article class="prod reveal" style="transition-delay:.14s">
        <div class="prod-img">
          <Image src={LifestyleNight} alt="Pikanté Verde" width={2340} height={4160} loading="lazy" />
        </div>
        <div class="prod-body">
          <div class="prod-row1">
            <h3>Suave</h3>
            <span class="price" data-v250="L 70 · 250ml" data-v570="L 150 · 570ml" data-v1l="L 260 · 1L">L 150 <span style="color:var(--text-4)">&middot; 570ml</span></span>
          </div>
          <p>Citrico, fresco, jalapeno verde y limon persa. La michelada de las 3pm en la alberca.</p>
          <div class="prod-variants">
            <button class="variant-pill" data-variant="v250">250ml</button>
            <button class="variant-pill active" data-variant="v570">570ml</button>
            <button class="variant-pill" data-variant="v1l">1 Litro</button>
          </div>
          <div class="prod-row2">
            <span class="chiles" aria-label="Picante 2 de 5">
              <Flame width={16} height={16} fill="currentColor" class='text-(--fire)' />
              <Flame width={16} height={16} fill="currentColor" class='opacity-50 text-(--fire)' />
              <Flame width={16} height={16} fill="currentColor" class='opacity-50 text-(--fire)' />
              <Flame width={16} height={16} fill="currentColor" class='opacity-50 text-(--fire)' />
              <Flame width={16} height={16} fill="currentColor" class='opacity-50 text-(--fire)' />
            </span>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.prod').forEach((card) => {
    const pills = card.querySelectorAll<HTMLButtonElement>('.variant-pill');
    const priceEl = card.querySelector<HTMLElement>('.price');

    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        pills.forEach(p => p.classList.remove('active'));
        pill.classList.add('active');

        const key = pill.dataset.variant as string;
        if (priceEl && priceEl.dataset[key]) {
          const [amount, size] = priceEl.dataset[key]!.split(' · ');
          priceEl.innerHTML = `${amount} <span style="color:var(--text-4)">&middot; ${size}</span>`;
        }
      });
    });
  });
</script>
