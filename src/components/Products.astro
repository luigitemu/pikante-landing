---
import { Flame } from '@lucide/astro';
import { Image } from 'astro:assets';
import ProductLimes from '../images/product-limes.webp';
import HeroFire from '../images/hero-fire.webp';
import LifestyleNight from '../images/lifestyle-night.webp';
---

<section class="products" id="sabores">
  <div class="container">
    <div class="section-head reveal">
      <div>
        <span class="eyebrow">03 / Sabores</span>
        <h2>Elige tu<br/><em>temperatura.</em></h2>
      </div>
      <p>Tres botellas. Tres formas de prender el rato. Todas hechas con la misma obsesion por el balance.</p>
    </div>
    <div class="prod-grid">
      <!-- Original -->
      <article class="prod reveal">
        <div class="prod-img">
          <span class="prod-tag hot">Mas vendido</span>
          <Image src={ProductLimes} alt="Pikante Original" width={1024} height={1536} loading="lazy" />
        </div>
        <div class="prod-body">
          <div class="prod-row1">
            <h3>Original</h3>
            <span class="price">L 129 <span style="color:#666">&middot; 320ml</span></span>
          </div>
          <p>El balance clasico: chile de arbol, limon, tamarindo. La puerta de entrada al fuego.</p>
          <div class="prod-row2">
            <span class="chiles" aria-label="Picante 3 de 5">
              <Flame width={16} height={16} fill="currentColor" class='text-[#ff6a00]' />
              <Flame width={16} height={16} fill="currentColor" class='text-[#ff6a00]' />
              <Flame width={16} height={16} fill="currentColor" class='text-[#ff6a00]' />
              <Flame width={16} height={16} fill="currentColor" class='text-[#ff6a00] opacity-50' />
              <Flame width={16} height={16} fill="currentColor" class='text-[#ff6a00] opacity-50' />
            </span>
            <!-- TODO: Add Cart Feature -->
            <!-- <button class="prod-cta">Agregar +</button> -->
          </div>
        </div>
      </article>
      <!-- Brutal -->
      <article class="prod reveal" style="transition-delay:.07s">
        <div class="prod-img">
          <span class="prod-tag">Edicion 02</span>
          <Image src={HeroFire} alt="Pikante Brutal" width={1024} height={1536} loading="lazy" />
        </div>
        <div class="prod-body">
          <div class="prod-row1">
            <h3>Brutal</h3>
            <span class="price">$149 <span style="color:#666">&middot; 320ml</span></span>
          </div>
          <p>Para los que no se andan con rodeos. Habanero ahumado, chile morita, jugo de naranja agria.</p>
          <div class="prod-row2">
            <span class="chiles" aria-label="Picante 5 de 5">
              <Flame width={16} height={16} fill="currentColor" class='text-[#ff6a00]' />
              <Flame width={16} height={16} fill="currentColor" class='text-[#ff6a00]' />
              <Flame width={16} height={16} fill="currentColor" class='text-[#ff6a00]' />
              <Flame width={16} height={16} fill="currentColor" class='text-[#ff6a00]' />
              <Flame width={16} height={16} fill="currentColor" class='text-[#ff6a00]' />
            </span>
            <!-- <button class="prod-cta">Agregar +</button> -->
          </div>
        </div>
      </article>
      <!-- Verde -->
      <article class="prod reveal" style="transition-delay:.14s">
        <div class="prod-img">
          <span class="prod-tag">Version suave</span>
          <Image src={LifestyleNight} alt="Pikante Verde" width={2340} height={4160} loading="lazy" />
        </div>
        <div class="prod-body">
          <div class="prod-row1">
            <h3>Verde</h3>
            <span class="price">L 129 <span style="color:#666">&middot; 320ml</span></span>
          </div>
          <p>Citrico, fresco, jalapeno verde y limon persa. La michelada de las 3pm en la alberca.</p>
          <div class="prod-row2">
            <span class="chiles" aria-label="Picante 2 de 5">
              <Flame width={16} height={16} fill="currentColor" class='text-[#ff6a00]' />
              <Flame width={16} height={16} fill="currentColor" class='text-[#ff6a00]' />
              <Flame width={16} height={16} fill="currentColor" class='text-[#ff6a00] opacity-50' />
              <Flame width={16} height={16} fill="currentColor" class='text-[#ff6a00] opacity-50' />
              <Flame width={16} height={16} fill="currentColor" class='text-[#ff6a00] opacity-50' />
            </span>
            <!-- <button class="prod-cta">Agregar +</button> -->
          </div>
        </div>
      </article>
    </div>
  </div>
</section>
