---
import { Image } from 'astro:assets';
import LifestylePool from '../images/lifestyle-pool.webp';
---

<section class="life reveal" id="vida">
  <div class="life-bg">
    <Image src={LifestylePool} alt="Pikanté en la fiesta" width={2813} height={1876} loading="lazy" />
  </div>
  <div class="life-content">
    <span class="eyebrow">05 / Vida Pikanté</span>
    <h2>Pikanté no se toma.<br/><em>Se vive.</em></h2>
    <div class="tags">
      <span>Rooftop</span>
      <span>Carne asada</span>
      <span>Brindis</span>
      <span>Noche urbana</span>
      <span>Despues del partido</span>
      <span>Antes del cover</span>
    </div>
  </div>
</section>
